APP_NAME="Fleet Console"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://fleet-console.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Optional: bcrypt hash for shared console sign-in when Fleet IdP password grant is not configured.
# Prefer storing the hash in the database: Console → Console settings (overrides this when set).
#   php -r "echo password_hash('your-long-random-secret', PASSWORD_BCRYPT), PHP_EOL;"
# FLEET_CONSOLE_PASSWORD_HASH=

# Optional: centralized sign-in via Fleet Auth (Laravel Passport). When configured, “Sign in with Fleet account” appears.
# FLEET_IDP_URL = Fleet Auth root only (e.g. https://fleet-auth.test), not this app’s callback URL.
#
# Register an authorization-code client in Fleet Auth with redirect {APP_URL}/auth/callback (unless you override the path).
# Fleet Console defaults (when env omitted): config/fleet_idp_overrides.php — session mode, /auth/callback,
# web+fleet.trusted_ip middleware (trusted IP allowlist applies to OAuth routes when set).
#
# FLEET_IDP_URL=https://fleet-auth.test
# FLEET_IDP_CLIENT_ID=
# FLEET_IDP_CLIENT_SECRET=
# Optional password-grant client: enables email + password on /login (same as Fleet Auth credentials).
# FLEET_IDP_PASSWORD_CLIENT_ID=
# FLEET_IDP_PASSWORD_CLIENT_SECRET=
# FLEET_IDP_REDIRECT_PATH=/auth/callback
# FLEET_IDP_WEB_MODE=session
# FLEET_IDP_WEB_MIDDLEWARE=web,fleet.trusted_ip
# Optional full redirect URI (must match Passport exactly): FLEET_IDP_REDIRECT_URI="${APP_URL}/auth/callback"

# Fleet operator tokens: per service in Console → Services (database).
# Console / API / alerts / polling / TLS verify / trusted IPs / health token / scheduler: Console → Console settings + Console → Alerts (database). No fleet_console config file.

# Browser CORS for /api/fleet/* . Empty = allow any origin (*). Otherwise comma-separated origins.
# FLEET_API_CORS_ORIGINS=

# Production hardening: use HTTPS and restrict cookies (see Laravel session docs).
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax

# Alert timeline DB rows are pruned daily (schedule). Override: php artisan fleet:prune-alert-events --days=
# Default retention: 90 days.
