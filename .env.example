APP_NAME="Fleet Console"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://fleet-console.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Web UI: single shared sign-in secret (pick one approach).
# Preferred for production: bcrypt hash so the raw password is not stored in .env.
#   php -r "echo password_hash('your-long-random-secret', PASSWORD_BCRYPT), PHP_EOL;"
# FLEET_CONSOLE_PASSWORD_HASH=
#
# Alternative: plain password (keep long and random). Ignored when FLEET_CONSOLE_PASSWORD_HASH is set.
FLEET_CONSOLE_PASSWORD=

# Read-only JSON: GET /api/fleet/targets, /api/fleet/targets/{key}, /api/fleet/summary, /api/fleet/alerts, …
# Use Authorization: Bearer <token> or X-Fleet-Api-Token.
# Leave empty to disable the API (404). Does not poll targets—uses stored samples only.
# FLEET_CONSOLE_API_TOKEN=

# Operator bearer tokens: set per service in the web UI (Console → Services), not here.

# Default poll base URL; {key} is replaced per app (beacon, jetty, lookout-monitor, …).
FLEET_CONSOLE_TARGET_URL_TEMPLATE="https://{key}.test"

# Set false only if local TLS to *.test fails from PHP (Herd CA). Prefer fixing trust store.
FLEET_CONSOLE_HTTP_VERIFY=true

# Optional: non-empty JSON array replaces default targets entirely (custom hosts/ports).
# Ignored when the database has at least one enabled row in fleet_targets (manage under Console → Services).
# Per-target optional keys: "description", "site_url" (UI link; defaults to base_url), "staging_site_url",
# "operator_token", "operator_path_prefix" (e.g. "/api/v1/operator" for Dply).
# FLEET_CONSOLE_TARGETS=[]

# Alerts when a target goes OK→error (and optional recovery / metric rules below).
# FLEET_ALERT_EMAIL=
# FLEET_ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/...
# FLEET_ALERT_ON_RECOVERY=false

# JSON: per-target or "*" rules. Path uses dot notation on operator summary JSON (e.g. users, metrics.status_pages).
# Example: {"beacon":[{"path":"users","min":1}],"*":[{"path":"metrics.foo","max":99999}]}
# FLEET_ALERT_METRIC_RULES={}

# Alert when rolling 24h OK% from stored polls drops below this (e.g. 99). Leave unset to disable.
# FLEET_ALERT_SLO_MIN_OK_PERCENT=99
# FLEET_ALERT_SLO_DEDUPE_HOURS=6

# When 7d raw sample count exceeds this, sparkline uses daily buckets (run fleet:aggregate-poll-daily). 0 = never.
# FLEET_DAILY_ROLLUP_SPARKLINE_AFTER_SAMPLES=800

# Optional JSON: per-target overrides (mute_alerts, alert_slo_min_ok_percent, alert_slo_dedupe_hours, webhook_urls[]).
# FLEET_CONSOLE_TARGET_OVERRIDES={"beacon":{"mute_alerts":true}}

# Extra alert webhook URLs (JSON array and/or single URL). Dispatched with Slack/email as JSON POST.
# FLEET_ALERT_WEBHOOK_URL=
# FLEET_ALERT_WEBHOOK_URLS=[]

# Comma-separated IPs/CIDRs allowed to use the web UI and protected fleet API routes. Empty = no restriction.
# FLEET_CONSOLE_TRUSTED_IPS=127.0.0.1,::1

# GET /api/fleet/health — when set, require ?token= or X-Fleet-Health-Token header.
# FLEET_HEALTH_TOKEN=

# Scheduled polling (php artisan schedule:work or system cron). Sends each service’s stored operator token like the dashboard.
# FLEET_BACKGROUND_POLL_ENABLED=false
# FLEET_POLL_INTERVAL_MINUTES=10

# Browser CORS for /api/fleet/* . Empty = allow any origin (*). Otherwise comma-separated origins.
# FLEET_API_CORS_ORIGINS=

# Production hardening: use HTTPS and restrict cookies (see Laravel session docs).
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax

# Alert timeline DB rows are pruned daily (schedule). Override: php artisan fleet:prune-alert-events --days=
# Default retention: 90 days.
